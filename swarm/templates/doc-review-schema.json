{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WarSignalAir Design Review Report",
  "description": "Schema for design document review findings — not code review, document quality review",
  "type": "object",
  "required": [
    "timestamp",
    "session_id",
    "project",
    "phase",
    "review_type",
    "findings",
    "summary"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of review"
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier"
    },
    "project": {
      "type": "string",
      "const": "WarSignalAir",
      "description": "Project name"
    },
    "phase": {
      "type": "string",
      "const": "0-precode",
      "description": "Project phase (always 0 for design-only validation)"
    },
    "review_type": {
      "type": "string",
      "const": "document",
      "description": "Review is document-based, not code-based"
    },
    "findings": {
      "type": "array",
      "description": "Array of design issues found",
      "items": {
        "type": "object",
        "required": [
          "category",
          "document",
          "severity",
          "description",
          "remediation"
        ],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "missing-doc",
              "incomplete-section",
              "inconsistency",
              "cross-ref-broken",
              "readiness-gap"
            ],
            "description": "Type of design issue"
          },
          "document": {
            "type": "string",
            "enum": [
              "CLAUDE.md",
              "ARCHITECTURE.md",
              "GAME_DESIGN.md",
              "PROJECT_PLAN.md",
              "ASSET_MANIFEST.md",
              "MILESTONES.md"
            ],
            "description": "Target document"
          },
          "section": {
            "type": [
              "string",
              "null"
            ],
            "description": "Specific section within document (optional)"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ],
            "description": "Impact severity"
          },
          "description": {
            "type": "string",
            "description": "What is missing or wrong?"
          },
          "evidence": {
            "type": "string",
            "description": "Quote or reference from document or validator output"
          },
          "remediation": {
            "type": "string",
            "description": "What needs to be added or fixed?"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "missing_docs",
        "incomplete_sections",
        "inconsistencies",
        "cross_ref_issues",
        "readiness_gaps",
        "total_issues",
        "ready_for_phase_1"
      ],
      "properties": {
        "missing_docs": {
          "type": "integer",
          "description": "Count of missing documents"
        },
        "incomplete_sections": {
          "type": "integer",
          "description": "Count of incomplete sections in existing docs"
        },
        "inconsistencies": {
          "type": "integer",
          "description": "Count of conflicting information"
        },
        "cross_ref_issues": {
          "type": "integer",
          "description": "Count of broken cross-references"
        },
        "readiness_gaps": {
          "type": "integer",
          "description": "Count of readiness optimization issues"
        },
        "total_issues": {
          "type": "integer",
          "description": "Total issues found"
        },
        "ready_for_phase_1": {
          "type": "boolean",
          "description": "Whether Phase 1 can start with current docs"
        }
      }
    }
  }
}
